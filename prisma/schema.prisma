// Sistema de Gestão de Fluxo Financeiro - Advocacia Clarissa Oliveira
// Schema baseado na Especificação Funcional §10 (Modelo de Dados).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================================
// AUTENTICAÇÃO E PERFIS
// =====================================================================

enum Perfil {
  ADMIN
  SECRETARIA
  PARCEIRO_LEITURA
}

model Usuario {
  id           String   @id @default(cuid())
  nome         String
  email        String   @unique
  senhaHash    String
  perfil       Perfil   @default(SECRETARIA)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  lancamentosCriados   Lancamento[]   @relation("LancamentoCriadoPor")
  distribuicoesCriadas Distribuicao[] @relation("DistribuicaoCriadoPor")
  auditorias           Auditoria[]

  @@map("usuario")
}

// =====================================================================
// CADASTROS BÁSICOS
// =====================================================================

model Cliente {
  id           String   @id @default(cuid())
  nome         String
  cpfCnpj      String?
  email        String?
  telefone     String?
  observacoes  String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  processos         Processo[]
  recebiveis        Recebivel[]
  ressarcimentos    Ressarcimento[]
  sucumbencias      Sucumbencia[]
  parceriasPagas    ParceriaPaga[]
  lancamentos       Lancamento[]
  itensDistribuicao ItemDistribuicao[]

  @@index([nome])
  @@map("cliente")
}

enum NaturezaProcesso {
  TRABALHISTA
  CIVEL
  PREVIDENCIARIO
  TRIBUTARIO
  FAMILIA
  OUTRO
}

enum StatusProcesso {
  EM_ANDAMENTO
  SUSPENSO
  ENCERRADO
  ARQUIVADO
}

model Processo {
  id             String           @id @default(cuid())
  clienteId      String
  numeroCnj      String?          @unique
  natureza       NaturezaProcesso @default(OUTRO)
  vara           String?
  tribunal       String?
  parteContraria String?
  status         StatusProcesso   @default(EM_ANDAMENTO)
  observacoes    String?
  ativo          Boolean          @default(true)
  criadoEm       DateTime         @default(now())
  atualizadoEm   DateTime         @updatedAt

  cliente        Cliente         @relation(fields: [clienteId], references: [id])
  recebiveis     Recebivel[]
  ressarcimentos Ressarcimento[]
  sucumbencias   Sucumbencia[]
  parceriasPagas ParceriaPaga[]
  lancamentos    Lancamento[]

  @@index([clienteId])
  @@index([status])
  @@map("processo")
}

enum TipoParceiro {
  PARCEIRO_EXTERNO
  FUNCIONARIO
}

model AdvogadoParceiro {
  id                          String       @id @default(cuid())
  nome                        String
  tipo                        TipoParceiro @default(PARCEIRO_EXTERNO)
  oab                         String?
  percentualPadraoSucumbencia Decimal?     @db.Decimal(5, 4)
  ativo                       Boolean      @default(true)
  criadoEm                    DateTime     @default(now())
  atualizadoEm                DateTime     @updatedAt

  recebiveis        Recebivel[]
  parceriasPagas    ParceriaPaga[]
  sucumbencias      Sucumbencia[]
  itensDistribuicao ItemDistribuicao[]

  @@map("advogado_parceiro")
}

enum TipoConta {
  CAIXA_FISICO
  CONTA_CORRENTE
  POUPANCA
  INVESTIMENTO
}

model ContaBancaria {
  id           String    @id @default(cuid())
  codigo       String    @unique // ex: DIN, INTER, CEF
  nome         String
  tipo         TipoConta @default(CONTA_CORRENTE)
  banco        String?
  agencia      String?
  conta        String?
  saldoInicial Decimal   @default(0) @db.Decimal(14, 2)
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt

  lancamentosConta  Lancamento[]  @relation("LancamentoConta")
  recebimentosConta Recebivel[]   @relation("RecebivelContaRecebimento")
  repassesConta     Recebivel[]   @relation("RecebivelContaRepasse")
  sucumbencias      Sucumbencia[] @relation("SucumbenciaContaRecebimento")
  despesasFixas     DespesaFixa[]

  @@map("conta_bancaria")
}

enum TipoCategoria {
  RECEITA
  DESPESA
}

model Categoria {
  id             String        @id @default(cuid())
  nome           String
  tipo           TipoCategoria
  isPessoal      Boolean       @default(false)
  categoriaPaiId String?
  ativo          Boolean       @default(true)
  criadoEm       DateTime      @default(now())
  atualizadoEm   DateTime      @updatedAt

  categoriaPai  Categoria?    @relation("CategoriaHierarquia", fields: [categoriaPaiId], references: [id])
  filhas        Categoria[]   @relation("CategoriaHierarquia")
  lancamentos   Lancamento[]
  sucumbencias  Sucumbencia[]
  despesasFixas DespesaFixa[]

  @@unique([nome, categoriaPaiId])
  @@map("categoria")
}

// =====================================================================
// RECEBÍVEIS (D. Janeiro ... D. Dezembro)
// =====================================================================

enum TipoParcela {
  NORMAL
  UNICA
  HONORARIOS_SUCUMBENCIA
  EXTRAORDINARIA
}

enum StatusRecebivel {
  PREVISTA
  RECEBIDA
  REPASSADA
  CANCELADA
}

model Recebivel {
  id                    String      @id @default(cuid())
  processoId            String
  clienteId             String // denormalizado p/ query
  dataPrevista          DateTime    @db.Date
  tipoParcela           TipoParcela @default(NORMAL)
  numeroParcela         Int?
  totalParcelas         Int?
  valorIntegral         Decimal     @db.Decimal(14, 2)
  valorParcela          Decimal     @db.Decimal(14, 2)
  ressarcimentoEmbutido Decimal     @default(0) @db.Decimal(14, 2)
  percHonorarios        Decimal     @db.Decimal(5, 4)
  parceiroId            String?
  percParceiro          Decimal?    @db.Decimal(5, 4)

  status             StatusRecebivel @default(PREVISTA)
  dataRecebimento    DateTime?       @db.Date
  contaRecebimentoId String?
  dataRepasseCliente DateTime?       @db.Date
  contaRepasseId     String?
  formaRepasse       String?

  observacoes  String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  processo         Processo          @relation(fields: [processoId], references: [id])
  cliente          Cliente           @relation(fields: [clienteId], references: [id])
  parceiro         AdvogadoParceiro? @relation(fields: [parceiroId], references: [id])
  contaRecebimento ContaBancaria?    @relation("RecebivelContaRecebimento", fields: [contaRecebimentoId], references: [id])
  contaRepasse     ContaBancaria?    @relation("RecebivelContaRepasse", fields: [contaRepasseId], references: [id])

  lancamentos    Lancamento[]
  ressarcimentos Ressarcimento[]
  distribuicao   Distribuicao?

  @@index([status, dataPrevista])
  @@index([clienteId, processoId])
  @@index([processoId])
  @@map("recebivel")
}

// =====================================================================
// DISTRIBUIÇÃO JURÍDICA (3ª camada — espec docs/arquitetura-financeira.md)
// =====================================================================

enum TipoBeneficiario {
  CLIENTE
  ESCRITORIO_CONTRATUAL
  ESCRITORIO_SUCUMBENCIA
  PARCEIRO
  PERITO
  FGTS
  RESSARCIMENTO
  CUSTAS
  OUTRO
}

enum StatusDistribuicao {
  RASCUNHO
  CONFIRMADA
  REVERTIDA
}

enum StatusItemDistribuicao {
  PENDENTE_REPASSE
  REPASSADO
  RETIDO_CUSTODIA
}

model Distribuicao {
  id                 String             @id @default(cuid())
  recebivelId        String             @unique
  valorBrutoRecebido Decimal            @db.Decimal(14, 2)
  dataRecebimento    DateTime           @db.Date
  observacoes        String?
  status             StatusDistribuicao @default(RASCUNHO)
  criadoPorId        String?
  criadoEm           DateTime           @default(now())
  atualizadoEm       DateTime           @updatedAt

  recebivel Recebivel          @relation(fields: [recebivelId], references: [id])
  criadoPor Usuario?           @relation("DistribuicaoCriadoPor", fields: [criadoPorId], references: [id])
  itens     ItemDistribuicao[]

  @@index([status])
  @@map("distribuicao")
}

model ItemDistribuicao {
  id             String                 @id @default(cuid())
  distribuicaoId String
  beneficiario   TipoBeneficiario
  descricao      String?
  valor          Decimal                @db.Decimal(14, 2)
  status         StatusItemDistribuicao @default(PENDENTE_REPASSE)

  // FKs polimórficos opcionais — preenchidos conforme beneficiario
  clienteId    String?
  parceiroId   String?
  lancamentoId String?

  observacoes  String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  distribuicao Distribuicao      @relation(fields: [distribuicaoId], references: [id], onDelete: Cascade)
  cliente      Cliente?          @relation(fields: [clienteId], references: [id])
  parceiro     AdvogadoParceiro? @relation(fields: [parceiroId], references: [id])
  lancamento   Lancamento?       @relation(fields: [lancamentoId], references: [id])

  @@index([distribuicaoId])
  @@index([beneficiario, status])
  @@map("item_distribuicao")
}

// =====================================================================
// MOVIMENTO DE CAIXA (lançamento)
// =====================================================================

enum TipoLancamento {
  ENTRADA
  SAIDA
  TRANSFERENCIA
}

model Lancamento {
  id          String         @id @default(cuid())
  data        DateTime       @db.Date
  descricao   String
  contaId     String
  tipo        TipoLancamento
  valor       Decimal        @db.Decimal(14, 2)
  categoriaId String

  clienteId          String?
  processoId         String?
  recebivelId        String?
  ressarcimentoId    String?
  transferenciaParId String?

  comprovanteUrl String?
  observacoes    String?
  criadoPorId    String?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  conta               ContaBancaria        @relation("LancamentoConta", fields: [contaId], references: [id])
  categoria           Categoria            @relation(fields: [categoriaId], references: [id])
  cliente             Cliente?             @relation(fields: [clienteId], references: [id])
  processo            Processo?            @relation(fields: [processoId], references: [id])
  recebivel           Recebivel?           @relation(fields: [recebivelId], references: [id])
  ressarcimento       Ressarcimento?       @relation(fields: [ressarcimentoId], references: [id])
  transferenciaPar    Lancamento?          @relation("LancamentoTransferencia", fields: [transferenciaParId], references: [id])
  parDe               Lancamento[]         @relation("LancamentoTransferencia")
  criadoPor           Usuario?             @relation("LancamentoCriadoPor", fields: [criadoPorId], references: [id])
  itensDistribuicao   ItemDistribuicao[]
  sucumbencia         Sucumbencia?         @relation("SucumbenciaLancamentoEntrada")
  despesaFixaPrevisao DespesaFixaPrevisao? @relation("DespesaFixaPrevisaoLancamento")

  @@index([data, contaId])
  @@index([categoriaId, data])
  @@index([recebivelId])
  @@index([clienteId])
  @@map("lancamento")
}

// =====================================================================
// RESSARCIMENTO
// =====================================================================

enum StatusRessarcimento {
  PAGO_PELO_ESCRITORIO
  REEMBOLSADO
}

model Ressarcimento {
  id            String              @id @default(cuid())
  clienteId     String
  processoId    String
  data          DateTime            @db.Date
  descricao     String
  valor         Decimal             @db.Decimal(14, 2)
  status        StatusRessarcimento @default(PAGO_PELO_ESCRITORIO)
  dataReembolso DateTime?           @db.Date
  recebivelId   String?
  criadoEm      DateTime            @default(now())
  atualizadoEm  DateTime            @updatedAt

  cliente     Cliente      @relation(fields: [clienteId], references: [id])
  processo    Processo     @relation(fields: [processoId], references: [id])
  recebivel   Recebivel?   @relation(fields: [recebivelId], references: [id])
  lancamentos Lancamento[]

  @@index([clienteId, processoId])
  @@index([status])
  @@map("ressarcimento")
}

// =====================================================================
// PARCERIAS
// =====================================================================

model ParceriaPaga {
  id             String    @id @default(cuid())
  parceiroId     String
  clienteId      String
  processoId     String
  dataAcordo     DateTime  @db.Date
  valorTotal     Decimal   @db.Decimal(14, 2)
  valorRecebido  Decimal   @default(0) @db.Decimal(14, 2)
  percHonorarios Decimal   @db.Decimal(5, 4)
  ressarcimentos Decimal   @default(0) @db.Decimal(14, 2)
  percParceiro   Decimal   @db.Decimal(5, 4)
  dataPgto       DateTime? @db.Date
  observacoes    String?
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  parceiro AdvogadoParceiro @relation(fields: [parceiroId], references: [id])
  cliente  Cliente          @relation(fields: [clienteId], references: [id])
  processo Processo         @relation(fields: [processoId], references: [id])

  @@index([parceiroId])
  @@index([clienteId, processoId])
  @@map("parceria_paga")
}

// =====================================================================
// SUCUMBÊNCIA
//
// Honorários arbitrados em sentença. Pertencem ao escritório por padrão.
// Se houver parceiro externo, uma fatia (percParceiroExterno do bruto)
// é devida a ele e fica como obrigação pendente até dataRepasseParceiroExterno.
// O valor bruto é registrado como ENTRADA no caixa no momento do cadastro.
// =====================================================================

model Sucumbencia {
  id              String   @id @default(cuid())
  clienteId       String
  processoId      String
  valorTotal      Decimal  @db.Decimal(14, 2)
  dataRecebimento DateTime @db.Date

  // Conta onde o dinheiro caiu e categoria do lançamento criado
  contaRecebimentoId    String
  categoriaLancamentoId String

  // Parceiro externo (opcional). Se preenchido, percParceiroExterno e
  // dataRepasseParceiroExterno fazem sentido.
  parceiroExternoId          String?
  percParceiroExterno        Decimal?  @db.Decimal(5, 4)
  dataRepasseParceiroExterno DateTime? @db.Date

  // Lançamento de ENTRADA criado automaticamente. Quando a sucumbência
  // é excluída ou alterada, o lançamento acompanha.
  lancamentoEntradaId String? @unique

  observacoes  String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  cliente             Cliente           @relation(fields: [clienteId], references: [id])
  processo            Processo          @relation(fields: [processoId], references: [id])
  parceiroExterno     AdvogadoParceiro? @relation(fields: [parceiroExternoId], references: [id])
  contaRecebimento    ContaBancaria     @relation("SucumbenciaContaRecebimento", fields: [contaRecebimentoId], references: [id])
  categoriaLancamento Categoria         @relation(fields: [categoriaLancamentoId], references: [id])
  lancamentoEntrada   Lancamento?       @relation("SucumbenciaLancamentoEntrada", fields: [lancamentoEntradaId], references: [id])

  @@index([dataRecebimento])
  @@index([clienteId, processoId])
  @@map("sucumbencia")
}

// =====================================================================
// AUDITORIA (histórico de alterações — §12.7)
// =====================================================================

enum AcaoAuditoria {
  CRIAR
  ATUALIZAR
  EXCLUIR
}

model Auditoria {
  id          String        @id @default(cuid())
  entidade    String // ex: "lancamento", "recebivel"
  entidadeId  String
  acao        AcaoAuditoria
  dadosAntes  Json?
  dadosDepois Json?
  usuarioId   String?
  criadoEm    DateTime      @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([entidade, entidadeId])
  @@index([criadoEm])
  @@map("auditoria")
}

// =====================================================================
// CONFIGURAÇÃO DO ESCRITÓRIO (singleton — usado na prestação de contas)
// =====================================================================

model Escritorio {
  id           String   @id @default("default")
  nome         String
  oab          String?
  cnpj         String?
  endereco     String?
  cidade       String?
  uf           String?  @db.VarChar(2)
  cep          String?
  telefone     String?
  email        String?
  observacoes  String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("escritorio")
}

// =====================================================================
// DESPESAS FIXAS RECORRENTES (luz, condomínio, internet, etc.)
//
// DespesaFixa é o "template" cadastrado pelo usuário (nome, valor estimado,
// dia de vencimento, conta e categoria padrão). DespesaFixaPrevisao é a
// instância mensal — gerada sob demanda — que vira "conta a pagar do mês".
// Quando o usuário marca a previsão como paga, um Lancamento de SAÍDA real
// é criado e vinculado.
// =====================================================================

model DespesaFixa {
  id            String  @id @default(cuid())
  nome          String
  categoriaId   String
  contaId       String
  valorEstimado Decimal @db.Decimal(14, 2)
  diaVencimento Int     @db.SmallInt // 1..31 (clampado pelo último dia do mês)
  ativo         Boolean @default(true)
  observacoes   String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  categoria Categoria             @relation(fields: [categoriaId], references: [id])
  conta     ContaBancaria         @relation(fields: [contaId], references: [id])
  previsoes DespesaFixaPrevisao[]

  @@index([ativo])
  @@map("despesa_fixa")
}

model DespesaFixaPrevisao {
  id             String   @id @default(cuid())
  despesaFixaId  String
  competencia    DateTime @db.Date // 1º dia do mês de referência (ex: 2026-07-01)
  dataVencimento DateTime @db.Date
  valorPrevisto  Decimal  @db.Decimal(14, 2)

  // Quando o usuário marca como paga, um Lancamento real é criado.
  lancamentoId  String?   @unique
  dataPagamento DateTime? @db.Date

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  despesaFixa DespesaFixa @relation(fields: [despesaFixaId], references: [id], onDelete: Cascade)
  lancamento  Lancamento? @relation("DespesaFixaPrevisaoLancamento", fields: [lancamentoId], references: [id])

  @@unique([despesaFixaId, competencia])
  @@index([competencia])
  @@index([dataVencimento])
  @@map("despesa_fixa_previsao")
}
