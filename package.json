    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
